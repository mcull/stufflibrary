{
  "buildCommand": "bash scripts/vercel-build.sh",
  "framework": "nextjs",
  "functions": {
    "app/**/*.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "PRISMA_GENERATE_DATAPROXY": "true"
  },
  "build": {
    "env": {
      "ENABLE_EXPERIMENTAL_COREPACK": "1"
    }
  },
  "crons": [
    { "path": "/api/cron/overdue", "schedule": "0 16 * * *" },
    { "path": "/api/cron/recompute-trust", "schedule": "30 16 * * *" }
  ]
}
