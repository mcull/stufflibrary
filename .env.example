# Database Configuration (Supabase)
# Production Database
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# Staging Database (for safe testing)
STAGING_DATABASE_URL="postgresql://postgres:[password]@[staging-host]:5432/postgres"
STAGING_DIRECT_URL="postgresql://postgres:[password]@[staging-host]:5432/postgres"

# Test Database (for automated testing)
TEST_DATABASE_URL="postgresql://postgres:[password]@[test-host]:5432/postgres"
TEST_DIRECT_URL="postgresql://postgres:[password]@[test-host]:5432/postgres"

# Database Environment Override (development|staging|production|test)
# Overrides NODE_ENV for database operations
DATABASE_ENV="development"

# Cache Configuration (Upstash Redis)
KV_URL="rediss://default:[password]@[host]:6379"
KV_REST_API_URL="https://[host].upstash.io"
KV_REST_API_TOKEN="your_upstash_api_token"
KV_REST_API_READ_ONLY_TOKEN="your_upstash_readonly_token"
REDIS_URL="rediss://default:[password]@[host]:6379"

# AI Services
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Hard daily spend cap in cents across all paid APIs (OpenAI, Gemini, Places).
# Optional; defaults to 1000 ($10/day). Requires Redis (KV_REST_API_*) to be active.
DAILY_SPEND_CAP_CENTS="1000"

# Admin access — comma-separated email allowlist. Anyone signing in (incl. via
# email code) with one of these emails gets admin. GitHub-username admins are
# also supported in code (admin-auth.ts).
ADMIN_EMAILS="you@example.com"

# Error tracking (Sentry) — all optional; Sentry is a no-op until DSN is set.
# DSN: Sentry project settings -> Client Keys. Use the same value for both.
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# Org + project slugs and an auth token enable source-map upload at build time.
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="stufflibrary"
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxx"

# Backup monitoring (scripts/backup-monitor.ts) — optional; the monitor no-ops
# with a clear message until both are set. Token: Supabase account -> Access
# Tokens. Ref: the project to monitor (e.g. the production project ref).
SUPABASE_ACCESS_TOKEN="sbp_xxxxxxxxxxxxxxxx"
SUPABASE_PROJECT_REF="your-project-ref"

# GitHub Integration
GITHUB_TOKEN="github_pat_xxxxxxxxxxxxxxxxxxxxxxxxx"

# Email Services
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"

# File Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
BLOB_BASE_URL="https://your-blob-id.public.blob.vercel-storage.com"
BLOB_UNIQUE_STORE_ID="store_yourBlobId"
BLOB_STORE_NAME="your-blob-store-name"

# Authentication (Future)
NEXTAUTH_SECRET="your_nextauth_secret_key_here"
NEXTAUTH_URL="http://localhost:3000"

# Application Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron auth — Vercel Cron sends `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET="generate-a-long-random-string"

# Development/Debug
DEBUG="false"
LOG_LEVEL="info"